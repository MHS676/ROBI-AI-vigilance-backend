// ============================================================
// FALCON SECURITY LIMITED
// Enterprise AI Surveillance System — Prisma Schema
// Stack: NestJS + Prisma + PostgreSQL
// 105 Centers | Multi-Tenant RBAC
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

/// System-wide roles for multi-tenant access control
enum Role {
  SUPER_ADMIN /// Full access across all 105 centers
  ADMIN       /// Local admin — manages a single Center
  AGENT       /// Assigned to one Table; limited read/write
}

/// Physical microphone channel designation
enum MicrophoneChannel {
  LEFT
  RIGHT
}

/// Current operational status of hardware
enum DeviceStatus {
  ONLINE
  OFFLINE
  MAINTENANCE
}

/// Lifecycle state of a device in the inventory
enum InventoryStatus {
  PENDING     /// Discovered via MQTT birth message — awaiting Super Admin approval
  ASSIGNED    /// Approved and provisioned to a specific Center
  OFFLINE     /// Was assigned but has gone offline (heartbeat timeout)
  REJECTED    /// Super Admin explicitly rejected this device
}

/// Hardware type reported in the MQTT birth message
enum InventoryDeviceType {
  ESP32         /// WiFi sensing / ESP32 node
  AI_MICROPHONE /// Networked AI microphone
  CAMERA        /// IP camera discovered via ONVIF / WS-Discovery
}

/// AI inference features that can be individually enabled / disabled per camera.
/// Stored as a JSON array on the Camera model so the set is extensible without
/// a new migration for each new model.
enum AiFeature {
  WEAPON  /// knife, gun, pistol, rifle, weapon detection
  FIGHT   /// physical altercation / aggression detection
  FALL    /// person-fall detection
  FIRE    /// fire and smoke detection
  CROWD   /// over-crowding / crowd density detection
}

/// Type of locally-stored media file recorded by the surveillance system.
enum MediaType {
  VIDEO         /// MP4 / HLS segment recorded from an RTSP camera stream
  AUDIO         /// WAV / PCM recorded from a microphone channel
  WIFI_SENSING  /// JSON-line log of raw CSI frames from an ESP32 node
}

// ============================================================
// USER — Authentication & RBAC
// ============================================================

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  password     String   /// bcrypt-hashed
  firstName    String
  lastName     String
  role         Role     @default(AGENT)
  isActive     Boolean  @default(true)

  /// SUPER_ADMIN: centerId is null (global scope)
  /// ADMIN / AGENT: centerId must be set (local scope)
  centerId     String?
  center       Center?  @relation("CenterUsers", fields: [centerId], references: [id], onDelete: SetNull)

  /// One Agent is assigned to exactly one Table (1:1 enforced via @unique on Table.agentId)
  assignedTable Table?  @relation("AgentTable")

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([centerId])
  @@index([role])
  @@map("users")
}

// ============================================================
// CENTER — Physical Branch (1 of 105)
// ============================================================

model Center {
  id          String   @id @default(cuid())
  name        String   /// e.g. "Falcon Branch — Ikeja"
  code        String   @unique /// e.g. "FAL-IKJ-001"
  address     String?
  city        String?
  state       String?
  country     String   @default("Nigeria")
  phone       String?
  isActive    Boolean  @default(true)
  mapUrl      String?  /// Uploaded floor-plan / site-map (SVG or PNG) — served from /uploads/center-maps/

  // ── Relations ──────────────────────────────────────────────
  users        User[]        @relation("CenterUsers")
  cameras      Camera[]      @relation("CenterCameras")
  espNodes     EspNode[]     @relation("CenterEspNodes")
  microphones  Microphone[]  @relation("CenterMicrophones")
  tables       Table[]       @relation("CenterTables")
  inventory    DeviceInventory[] @relation("CenterInventory")
  alerts       Alert[]       /// All AI/sensor alerts generated within this center
  auditLogs    AuditLog[]    @relation("CenterAuditLogs")  /// Anomaly/fall audit trail
  localMedia   LocalMedia[]  @relation("CenterLocalMedia")  /// On-disk recordings

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([code])
  @@map("centers")
}

// ============================================================
// CAMERA — Physical IP/CCTV Camera with RTSP stream
// ============================================================

model Camera {
  id           String       @id @default(cuid())
  name         String       /// e.g. "CAM-01 - Reception"
  rtspUrl      String       /// e.g. "rtsp://admin:pass@192.168.1.10:554/stream1"
  ipAddress    String?
  model        String?      /// Hardware model / brand
  status       DeviceStatus @default(ONLINE)
  isActive     Boolean      @default(true)

  /// Enabled AI inference features for this camera.
  /// Stored as a JSON array, e.g. ["WEAPON","FALL","FIGHT"].
  /// Defaults to all features enabled on first save.
  /// Maps to AiFeature enum values — validated in the DTO layer.
  aiFeatures   Json         @default("[\"WEAPON\",\"FIGHT\",\"FALL\",\"FIRE\",\"CROWD\"]")

  centerId     String
  center       Center       @relation("CenterCameras", fields: [centerId], references: [id], onDelete: Cascade)

  /// ONE Camera belongs to exactly ONE Table (enforced via @unique on Table.cameraId)
  table        Table?       @relation("CameraTable")
  alerts       Alert[]      /// AI-generated alerts captured by this camera

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([centerId])
  @@index([status])
  @@map("cameras")
}

// ============================================================
// ESP NODE — WiFi Sensing Device (ESP32 / ESP8266)
// ============================================================

model EspNode {
  id           String       @id @default(cuid())
  name         String       /// e.g. "ESP-NODE-01"
  macAddress   String       @unique /// Hardware MAC address
  ipAddress    String?      /// Dynamic DHCP IP
  firmwareVer  String?      /// e.g. "v2.1.4"
  status       DeviceStatus @default(ONLINE)
  isActive     Boolean      @default(true)
  lastSeenAt   DateTime?    /// Last heartbeat timestamp

  centerId     String
  center       Center       @relation("CenterEspNodes", fields: [centerId], references: [id], onDelete: Cascade)

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([centerId])
  @@index([macAddress])
  @@map("esp_nodes")
}

// ============================================================
// MICROPHONE — Audio capture device (Left / Right channel)
// ============================================================

model Microphone {
  id           String             @id @default(cuid())
  name         String             /// e.g. "MIC-TABLE-03-LEFT"
  channel      MicrophoneChannel  /// LEFT or RIGHT
  ipAddress    String?
  model        String?
  status       DeviceStatus       @default(ONLINE)
  isActive     Boolean            @default(true)

  centerId     String
  center       Center             @relation("CenterMicrophones", fields: [centerId], references: [id], onDelete: Cascade)

  /// ONE Microphone belongs to exactly ONE Table (enforced via @unique on Table.microphoneId)
  table        Table?             @relation("MicrophoneTable")

  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([centerId])
  @@index([channel])
  @@map("microphones")
}

// ============================================================
// TABLE — CORE MODEL
// Physical customer-service desk / workstation.
// Uniquely links:
//   • ONE Camera        (with a Bounding Box: x, y, w, h)
//   • ONE Microphone    (Left or Right channel)
//   • ONE Agent (User)
// All enforced at DB level via @unique constraints.
// ============================================================

model Table {
  id           String   @id @default(cuid())
  name         String   /// e.g. "Table 01 — Teller A"
  tableNumber  Int      /// Physical table number within center
  isActive     Boolean  @default(true)
  notes        String?

  // ── Center (multi-tenant anchor) ───────────────────────────
  centerId     String
  center       Center   @relation("CenterTables", fields: [centerId], references: [id], onDelete: Cascade)

  // ── Camera + Bounding Box ──────────────────────────────────
  /// @unique: enforces ONE camera per table (and one table per camera)
  cameraId     String   @unique
  camera       Camera   @relation("CameraTable", fields: [cameraId], references: [id])

  /// Bounding box within camera frame: { "x": 100, "y": 50, "w": 300, "h": 200 }
  /// Pixels or normalised [0–1] floats — agreed at integration time
  boundingBox  Json

  // ── Microphone ─────────────────────────────────────────────
  /// @unique: enforces ONE microphone per table (and one table per microphone)
  microphoneId String   @unique
  microphone   Microphone @relation("MicrophoneTable", fields: [microphoneId], references: [id])

  // ── Agent ──────────────────────────────────────────────────
  /// @unique: enforces ONE agent per table (and one table per agent)
  agentId      String   @unique
  agent        User     @relation("AgentTable", fields: [agentId], references: [id])

  // ── Spatial Gating — 5-foot WiFi / Audio zone ──────────────
  /// Pixel coordinates of the ESP32 WiFi sensing zone on the floor plan.
  /// Used for 5-foot spatial gating: only fire alerts when a person is
  /// detected within this box around the service desk.
  wifiZoneX        Int? /// Top-left X of the WiFi gate zone (pixels)
  wifiZoneY        Int? /// Top-left Y of the WiFi gate zone (pixels)
  wifiZoneWidth    Int? /// Width of the WiFi gate zone (pixels)
  wifiZoneHeight   Int? /// Height of the WiFi gate zone (pixels)

  /// Decibel threshold above which the microphone triggers an audio alert.
  /// Overrides the system default when set. Typical range: 50–120 dB.
  audioThresholdDb Int? /// Per-table audio alert threshold in dB

  alerts       Alert[] /// AI/sensor alerts at this table
  auditLogs    AuditLog[]  @relation("TableAuditLogs")  /// Anomaly/fall audit trail
  localMedia   LocalMedia[] @relation("TableLocalMedia") /// On-disk recordings at this table

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  /// A center cannot have two tables with the same number
  @@unique([centerId, tableNumber])
  @@index([centerId])
  @@map("tables")
}

// ============================================================
// DEVICE INVENTORY — Zero-Config Hardware Provisioning
// Tracks every device that has ever announced itself via the
// MQTT birth topic (falcon/discovery/pending) or ONVIF scan.
//
// Lifecycle:
//   PENDING → (Super Admin assigns) → ASSIGNED
//   PENDING → (Super Admin rejects) → REJECTED
//   ASSIGNED → (heartbeat timeout)  → OFFLINE
// ============================================================

model DeviceInventory {
  id               String              @id @default(cuid())
  deviceType       InventoryDeviceType

  /// Hardware MAC address — unique identifier from the device itself
  macAddress       String?             @unique
  ipAddress        String?             /// Current IP (DHCP — may change)
  firmwareVer      String?             /// e.g. "v2.1.4"
  model            String?             /// Hardware model / brand
  hostname         String?             /// mDNS hostname if reported
  manufacturer     String?             /// e.g. "Hikvision", "Tiandy"

  /// For cameras discovered via ONVIF/WS-Discovery
  onvifXAddr       String?             /// ONVIF service URL
  rtspUrl          String?             /// Detected RTSP stream URL

  status           InventoryStatus     @default(PENDING)

  /// Set once Super Admin approves and assigns to a center
  centerId         String?
  center           Center?             @relation("CenterInventory", fields: [centerId], references: [id], onDelete: SetNull)

  /// Raw MQTT birth payload stored for diagnostics
  discoveryPayload Json?
  /// Config that was MQTT-published back to the device on provisioning
  provisionConfig  Json?

  lastSeenAt       DateTime?           /// Last heartbeat / birth message timestamp
  provisionedAt    DateTime?           /// When provisioning config was sent

  notes            String?

  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([status])
  @@index([deviceType])
  @@index([centerId])
  @@map("device_inventory")
}

// ============================================================
// ALERT — Persisted AI / Sensor Alert Record
// Created whenever the inference pipeline or a sensor fires an
// alert that meets the confidence / threshold criteria.
// The evidence JPEG frame is uploaded to S3 and the presigned
// URL stored in imageUrl for audit and review.
// ============================================================

model Alert {
  id         String   @id @default(uuid())

  /// Alert category — mirrors AiFeature values plus sensor-derived events.
  /// e.g. "WEAPON", "FALL", "FIGHT", "FIRE", "CROWD",
  ///      "HIGH_AUDIO", "WIFI_FALL", "DEVICE_OFFLINE"
  type       String

  /// Severity level: "CRITICAL" | "HIGH" | "MEDIUM" | "LOW" | "INFO"
  severity   String

  /// Model / sensor confidence score (0.0 – 1.0)
  confidence Float

  /// S3 presigned URL of the JPEG evidence frame captured at alert time (optional)
  imageUrl   String?

  timestamp  DateTime @default(now())

  // ── Relations ──────────────────────────────────────────────
  centerId   String
  center     Center   @relation(fields: [centerId], references: [id], onDelete: Cascade)

  tableId    String?
  table      Table?   @relation(fields: [tableId], references: [id], onDelete: SetNull)

  cameraId   String?
  camera     Camera?  @relation(fields: [cameraId], references: [id], onDelete: SetNull)

  @@index([centerId])
  @@index([tableId])
  @@index([cameraId])
  @@index([type])
  @@index([severity])
  @@index([timestamp])
  @@map("alerts")
}

// ============================================================
// LOCAL MEDIA — On-Disk Recording Index
// Metadata registry for every file written to the local Linux
// server's hard drive by the RecordingService.
//
// Physical layout on disk:
//   /records/{centerId}/{tableId}/{YYYY-MM-DD}/{mediaType}/
//       <cuid>_cam<N>.mp4   (VIDEO)
//       <cuid>_mic<N>.wav   (AUDIO)
//       <cuid>_csi.jsonl    (WIFI_SENSING)
//
// cameraNumber / micNumber are indexed for fast per-device searches.
// ============================================================

model LocalMedia {
  id             String    @id @default(cuid())

  /// MediaType enum: VIDEO | AUDIO | WIFI_SENSING
  mediaType      MediaType

  /// Absolute path on the Linux server, e.g.
  /// /records/clx.../clx.../2026-04-18/VIDEO/clx..._cam1.mp4
  absolutePath   String    @unique

  /// File size in bytes — updated once the recording is finalised
  fileSize       BigInt    @default(0)

  /// Physical camera channel number on the DVR (1, 2, 3 …)
  /// NULL for AUDIO and WIFI_SENSING records
  cameraNumber   Int?

  /// Physical microphone number in the center (1, 2, 3 …)
  /// NULL for VIDEO and WIFI_SENSING records
  micNumber      Int?

  // ── Relations ──────────────────────────────────────────────
  centerId       String
  center         Center    @relation("CenterLocalMedia", fields: [centerId], references: [id], onDelete: Cascade)

  tableId        String?
  table          Table?    @relation("TableLocalMedia", fields: [tableId], references: [id], onDelete: SetNull)

  /// ISO date string of the recording session, e.g. "2026-04-18"
  /// Denormalised here so we can filter without a date-trunc on createdAt
  recordingDate  String

  /// Duration of the recording in seconds (set when file is closed)
  durationSec    Float?

  /// Optional human-readable notes / tags (e.g. alert correlation ID)
  notes          String?

  createdAt      DateTime  @default(now())

  /// ── Indexes for fast per-device search ───────────────────
  @@index([centerId])
  @@index([tableId])
  @@index([cameraNumber])   /// fast lookup by camera channel
  @@index([micNumber])      /// fast lookup by microphone number
  @@index([mediaType])
  @@index([recordingDate])
  @@index([centerId, recordingDate])
  @@map("local_media")
}

// ============================================================
// AUDIT LOG — WiFi CSI Anomaly / Fall Detection Audit Trail
//
// Created by WifiAnomalyService whenever the EMA-based anomaly
// detector fires, regardless of whether the event crosses the
// CRITICAL alert threshold.  Stores raw diagnostic data so
// operators can tune thresholds and review near-misses.
// ============================================================

model AuditLog {
  id            String   @id @default(cuid())

  /// Event type — e.g. "FALL_DETECTED", "SUDDEN_MOVEMENT", "ANOMALY"
  eventType     String

  /// Detection source — e.g. "WIFI_CSI_EMA"
  source        String

  /// MAC address or CUID of the ESP32 node that generated the CSI data
  nodeId        String

  /// EMA value at the time of detection (baseline moving average)
  emaValue      Float

  /// Mean amplitude of the current CSI frame that triggered the anomaly
  currentAmplitude Float

  /// Ratio of currentAmplitude / emaValue — how far above baseline
  deviationRatio  Float

  /// Algorithm-derived confidence score 0.0 – 1.0
  confidence    Float

  /// Raw CSI sample array + extra diagnostics packed as JSON
  metadata      Json?

  // ── Relations ──────────────────────────────────────────────
  centerId      String
  center        Center   @relation("CenterAuditLogs", fields: [centerId], references: [id], onDelete: Cascade)

  tableId       String?
  table         Table?   @relation("TableAuditLogs", fields: [tableId], references: [id], onDelete: SetNull)

  createdAt     DateTime @default(now())

  @@index([centerId])
  @@index([tableId])
  @@index([nodeId])
  @@index([eventType])
  @@index([createdAt])
  @@map("audit_logs")
}
